# Server Configuration
PORT=5000
NODE_ENV=development

# Database Configuration
# Atlas example (allow 30s for first SRV connect on slow networks)
MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/patentbridge?retryWrites=true&w=majority&appName=Cluster0

# Security Configuration
JWT_SECRET=patentbridge-super-secret-key-12345

# Optional: public DNS when local resolver blocks Razorpay (api.razorpay.com)
# DNS_SERVERS=8.8.8.8,1.1.1.1,8.8.4.4

# Razorpay Integration Configuration
RAZORPAY_KEY_ID=rzp_test_xxxxx
RAZORPAY_KEY_SECRET=your_razorpay_secret

# AI Analysis — use Google Gemini (recommended for now)
# Get key at https://aistudio.google.com/apikey — must start with AIza...
AI_ANALYSIS_PROVIDER=gemini
GEMINI_API_KEY=AIzaSy_your_key_here
GEMINI_MODEL=gemini-2.0-flash

# Optional: MIET LLM gateway (fallback if Gemini fails)
# LLM_API_KEY=
# LLM_API_ENDPOINT=https://ai-services.mietjmu.in/gateway/llm/chat
# LLM_MODEL=qwen3:latest
